rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Receipt images — users can only access their own receipts
    // Path structure: users/{userId}/receipts/{receiptId}/{filename}
    // Filenames: original.jpg, image.jpg, thumb.jpg
    match /users/{userId}/receipts/{receiptId}/{filename} {
      // Read: authenticated owner only
      allow read: if request.auth != null && request.auth.uid == userId;

      // Write: authenticated owner, image files only, max 10MB
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Delete: authenticated owner only
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
